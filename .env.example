PORT=3003
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pm2_manager

# JWT — REQUIRED. Generate with: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Super Admin (seeded on first run)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=changeme

# PM2 (when running inside Docker with /root/.pm2 mounted)
PM2_HOME=/root/.pm2
PM2_BIN=pm2