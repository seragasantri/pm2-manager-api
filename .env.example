PORT=3003
NODE_ENV=development

# Database
# IMPORTANT: when running inside Docker, DB_HOST must NOT be "localhost"
# (that resolves to the container itself, not the host machine). Use one of:
#   - host.docker.internal   (Docker Desktop on Mac/Windows; add
#                             extra_hosts: ["host.docker.internal:host-gateway"]
#                             in docker-compose for Linux)
#   - 172.17.0.1             (default Docker bridge gateway on Linux)
#   - <HOST_LAN_IP>          (any routable IP of the host running MySQL)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pm2_manager

# JWT — REQUIRED. Generate with: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Super Admin (seeded on first run)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=changeme

# PM2 (when running inside Docker with /root/.pm2 mounted)
PM2_HOME=/root/.pm2
PM2_BIN=pm2